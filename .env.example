# ============================================
# N8N 工作流环境变量（GitHub Trending - 01）
# 命名规范：N8N_XX_服务_用途
# ============================================

# --------------------------------------------
# 飞书开放平台配置
# --------------------------------------------

# 飞书应用 App ID（在飞书开放平台创建应用后获取）
N8N_01_FEISHU_APP_ID=your_app_id_here

# 飞书应用 App Secret
N8N_01_FEISHU_APP_SECRET=your_app_secret_here

# 飞书机器人 Webhook 地址（用于发送群消息通知）
N8N_01_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# --------------------------------------------
# 飞书多维表格配置
# --------------------------------------------

# 多维表格 App Token（在多维表格 URL 中获取）
N8N_01_FEISHU_BITABLE_TOKEN=your_bitable_token_here

# 多维表格 - 经典项目表 ID
N8N_01_FEISHU_TABLE_CLASSIC=your_classic_table_id_here

# 多维表格 - 新锐项目表 ID
N8N_01_FEISHU_TABLE_TRENDING=your_trending_table_id_here

# --------------------------------------------
# Ollama 本地 LLM 配置
# --------------------------------------------

# Ollama 服务地址
N8N_01_OLLAMA_HOST=http://localhost

# Ollama 服务端口
N8N_01_OLLAMA_PORT=11434
